@page "/restocks/createrestock"
@inject NavigationManager navigation
@using AppForSEII2526.Web.Components.Shared
@using AppForSEII2526.Web.API
@using Microsoft.AspNetCore.Authorization
@inject AppForSEII2526APIClient apiclient
@inject ILogger<CreateRestock> logger
@inject RestockStateContainer restockState

<h3>Create Restock</h3>

<EditForm Model="restock" OnValidSubmit="OpenDialog">
    <div class="row">
        <DataAnnotationsValidator />
        <ValidationSummary class="row alert alert-danger" />
    </div>
    <div class="row alert alert-danger" role="alert" hidden="@hideErrors">
        <p id="ErrorsShown">Errors: @messageError</p>
    </div>

    <div class="row g-3">
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="restock.ApplicationUserName" class="form-control" id="UserName" readonly />
                <label for="UserName">Administrator User</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="restock.Title" class="form-control" id="RestockTitle" />
                <label for="RestockTitle">Restock Title (*)</label>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputTextArea @bind-Value="restock.DeliveryAddress" class="form-control" id="DeliveryAddress" style="height: 100px" />
                <label for="DeliveryAddress">Delivery Address (*)</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputTextArea @bind-Value="restock.Description" class="form-control" id="Description" style="height: 100px" />
                <label for="Description">Description (Must start with 'Restock for')</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputDate @bind-Value="restock.ExpectedDate" class="form-control" id="ExpectedDate" />
                <label for="ExpectedDate">Expected Date</label>
            </div>
        </div>
    </div>

    <div class="row g-2">
        <div class="col-md">
            <div class="form-floating">
                <button class="btn btn-primary" type="submit" id="Submit">
                    Confirm Restock
                </button>
            </div>
        </div>
    </div>

    <h4>Restock Items Detail</h4>
    <p><b>Date:</b> @restock.RestockDate.ToString("dd/MM/yyyy")</p>
    <p>
        <b>Total Estimated Price:</b> @TotalCost.ToString("F2") €
        <button class="btn btn-outline-primary" type="button" @onclick="ModifyRestockItems" id="ModifyItems">
            Modify Items
        </button>
    </p>

    <div class="mh-100 table-responsive">
        <table class="table table-condensed table-hover" id="TableOfRestockItems">
            <thead>
                <tr>
                    <th>Item Name</th>
                    <th>Brand</th>
                    <th>Current Stock</th>
                    <th>Price</th>
                    <th>Quantity to Buy (*)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in restock.RestockItems)
                {
                    <tr id="ItemData_@item.ItemId">
                        <td>@item.Name</td>
                        <td>@item.Brand</td>
                        <td>@item.QuantityForRestock</td>
                        <td>@(item.PriceOfRestock?.ToString("F2") ?? "0") €</td>
                        <td>
                            <InputNumber @bind-Value="item.QuantityForRestock" class="form-control" id="@($"quantity_{item.ItemId}")" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</EditForm>

@if (DialogIsOpen)
{
    <Dialog Caption="Create Restock"
            Message="Do you want to proceed to create this restock order?"
            OnClose="@OnDialogClose"
            Type=Dialog.Category.SaveNot>
    </Dialog>
}

@code {
    private string messageError = "";
    private bool hideErrors { get { return messageError.Length == 0; } }
    private bool DialogIsOpen;

    private RestockForCreateDTO restock => restockState.Restock;

    private double TotalCost
    {
        get
        {
            double total = restock.RestockItems.Sum(ri => (ri.PriceOfRestock ?? 0) * ri.QuantityForRestock);
            return total;
        }
    }

    private void ModifyRestockItems()
    {
        navigation.NavigateTo("/restock/selectitemsforrestock");
    }

    private void OpenDialog()
    {
        DialogIsOpen = true;
    }

    private async Task OnDialogClose(bool isOk)
    {
        DialogIsOpen = false;
        if (isOk)
        {
            if (restock.RestockItems.Count > 0)
            {
                try
                {
                    var created = await apiclient.CreateRestockAsync(restock);

                    restockState.RestockProcessed();

                    navigation.NavigateTo($"/restocks/detailrestock/?RestockID={created.Id}");
                }
                catch (ApiException<ValidationProblemDetails> apiexceptionvalidation)
                {
                    if (apiexceptionvalidation.Result.Errors != null)
                    {
                        messageError = "";
                        foreach (var errors in apiexceptionvalidation.Result.Errors.Values)
                        {
                            var errorMessages = string.Join(" (*) ", errors);
                            messageError = string.Join("(*) ", messageError, errorMessages);
                        }
                    }
                }
                catch (ApiException apiexception)
                {
                    messageError = "Error while processing your request (Conflict or Server Error). Please try again.";
                }
            }
        }
    }

    [CascadingParameter]
    private Task<AuthenticationState>? authenticationState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        restock.RestockDate = DateTime.Now;

        if (authenticationState is not null)
        {
            var authState = await authenticationState;
            var user = authState?.User;

            if (user is not null && user.Identity is not null && user.Identity.IsAuthenticated)
            {
                restock.ApplicationUserName = user.Identity.Name ?? "";
            }
        }

        restock.Title = restock.Title ?? "";
        restock.DeliveryAddress = restock.DeliveryAddress ?? "";
    }
}