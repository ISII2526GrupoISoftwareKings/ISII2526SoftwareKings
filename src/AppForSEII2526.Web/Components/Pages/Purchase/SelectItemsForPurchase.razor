@page "/purchase/selectitemsforpurchase"

@using Microsoft.AspNetCore.Authorization
@using AppForSEII2526.Web.API
@inject AppForSEII2526APIClient apiclient
@inject ILogger<SelectItemsForPurchase> logger
@inject PurchaseStateContainer purchaseState
@inject NavigationManager navigation

@attribute [Authorize]

<h3>Select Items For Purchase</h3>
<div class="container-fluid">
    <div class="row alert alert-danger" role="alert" hidden="@hideErrors">
        <p id="ErrorsShown">Errors: @errors</p>
    </div>
    <div class="row">
        <div class="col-8">
            <div class="row">
                <div class="col">
                    <div class="input-group mb-3">
                        <span class="input-group-text" id="basic-addon1">Item Name</span>
                        <input type="text" id="inputItemName" @bind=itemName class="form-control" placeholder="Item Name" aria-label="Item Name" aria-describedby="basic-addon1">
                    </div>
                </div>
                <div class="col">
                    <div class="input-group mb-3">
                        <span class="input-group-text" id="basic-addon2">Brand</span>
                        <select class="form-select" aria-label="Default select" @bind="itemBrandSelected" id="selectBrand">
                            <option value="All" selected>All</option>
                            @foreach (string brandName in brandNames) {
                                <option value="@brandName" id="brandNameSelected_@brandName">@brandName</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col">
                    <button type="button" class="btn btn-primary" @onclick=@SearchItems id="searchItems">Search items</button>
                </div>
            </div>
            <div class="row">
                @if (items == null) {
                    <p>Loading items....</p>
                }
                else if (items.Count == 0)
                {
                    <div class="alert alert-warning" role="alert">
                        <p>There are no items available for purchase.</p>
                        <button type="button" class="btn btn-secondary" @onclick="@(() => navigation.NavigateTo("/"))">Go back to Home</button>
                    </div>
                }
                else
                {
                    <div class="mh-100 table-responsive">
                        <table class="table table-condensed table-hover" id="TableOfItems">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Brand</th>
                                    <th>Description</th>
                                    <th>Price</th>
                                    <th>Available</th>
                                    <th>Add</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in items) {
                                    <tr id="ItemData_@item.Name">
                                        <td>@item.Name</td>
                                        <td>@item.Brand</td>
                                        <td>@item.Description</td>
                                        <td>@item.Price</td>
                                        <td>@item.QuantityAvailableForPurchase</td>
                                        <td>
                                            <button class="btn btn-outline-secondary" id="itemToPurchase_@item.Name" @onclick="@(() => AddItem(item))">Add</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
        <div class="col-2" hidden="@hidePurchaseCart">
            <div class="row">
                <h3>Shopping Cart</h3>
            </div>
            @foreach (PurchaseItemDTO item in purchase.PurchaseItems) {
                <div class="row mb-2">
                    <div class="card">
                        <div class="card-body">
                            <h6 class="card-title">@item.Name</h6>
                            <p class="card-text small">
                                <strong>Brand:</strong> @item.Brand<br/>
                                <strong>Quantity:</strong> @item.AmountBought<br/>
                                <strong>Price:</strong> @item.Price€<br/>
                                <strong>Total:</strong> @((item.Price * item.AmountBought).ToString("F2"))€
                            </p>
                            <button type="button" class="btn btn-sm btn-danger" id="removeItem_@item.Name" @onclick="@(() => RemovePurchaseItem(item))">Remove</button>
                        </div>
                    </div>
                </div>
            }
            <div class="row mb-2">
                <button type="button" class="btn btn-primary" id="purchaseItemsButton" @onclick=@PurchaseItems>Buy</button>
            </div>
            <div class="row">
                <button type="button" class="btn btn-secondary" id="backToModifyButton" @onclick=@BackToModify>Back to modify</button>
            </div>
        </div>
    </div>
</div>

@implements IDisposable

@code {
    private string itemBrandSelected;
    private ICollection<string>? brandNames = new List<string>();
    private bool hidePurchaseCart { get { return purchase.PurchaseItems.Count == 0; } }
    private ICollection<ItemForPurchasingDTO> items;
    private bool hideErrors { get { return errors.Length == 0; } }
    private string errors = "";
    private string itemName { get; set; }
    private string itemBrand { get; set; }
    private PurchaseForCreateDTO purchase => purchaseState.Purchase;

    private void AddItem(ItemForPurchasingDTO item) {
        purchaseState.AddItemToPurchase(item);
    }

    private void RemovePurchaseItem(PurchaseItemDTO item) {
        purchaseState.RemoveItemFromPurchase(item);
    }

    public async void SearchItems() {
        itemBrand = itemBrandSelected == "All" ? null : itemBrandSelected;

        try {
            items = await apiclient.GetItemsForPurchasingAsync(itemName, itemBrand);
            errors = "";
            // No need to extract brands anymore - they're loaded separately
        }
        catch (ApiException ex) {
            logger.LogError($"{DateTime.Now} Error: {ex}");
            errors = "Error while connecting to the system";
        }
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync() {
        try {
            // Load brands from the dedicated endpoint
            brandNames = await apiclient.GetBrandsAsync(null);
            
            if (brandNames == null) {
                brandNames = new List<string>();
            }
            
            // Also load initial items (optional - you might want to load items only after user searches)
            items = await apiclient.GetItemsForPurchasingAsync(null, null);
            errors = "";
        }
        catch (ApiException ex) {
            if (brandNames == null) brandNames = new List<string>();
            logger.LogError("Error! There was an error while connecting to the GetBrandsAsync service");
            errors = "Error while loading brands";
        }

        // Subscribe to purchase state changes
        purchaseState.OnChange += StateHasChanged;
    }

    public void Dispose() {
        purchaseState.OnChange -= StateHasChanged;
    }

    private void PurchaseItems() {
        navigation.NavigateTo("/purchase/createpurchase");
    }

    private void BackToModify() {
        // This allows the user to continue modifying the shopping cart
        // The cart is already visible, so this just ensures focus is on the items list
        StateHasChanged();
    }
}

